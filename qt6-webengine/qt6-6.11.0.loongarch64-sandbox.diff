+// The state of Landlock support on the system.
+// Used to report through UMA.
+enum LandlockState {
+  kEnabled = 0,
+  kDisabled = 1,
+  kNotSupported = 2,
+  kUnknown = 3,
+  kMaxValue = kUnknown,
