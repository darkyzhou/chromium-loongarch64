+struct ChromeRuntimeAPIDelegate::UpdateCheckInfo {
+  std::unique_ptr<net::BackoffEntry> backoff =
+      std::make_unique<net::BackoffEntry>(BackoffPolicy::Get(), g_test_clock);
+  std::vector<UpdateCheckCallback> callbacks;
+};
