+#else
+#define XNN_UNALIGNED __unaligned
+#endif
+#else
+#error "Platform-specific implementation of XNN_UNALIGNED required"
+#endif
+
+#define XNN_COUNT_OF(array) (sizeof(array) / sizeof(0 [array]))
